{
  "name": "podcast-search",
  "private": true,
  "workspaces": ["shared", "server", "web"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=web\"",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=web",
    "migrate": "npm run migrate --workspace=server",
    "seed": "npm run seed --workspace=server",
    "ingest": "npm run ingest --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
